[Desktop Entry]
Type=Application
Name=bbcat
GenericName=ANSI Art Viewer
Comment=View ANSI and BBS art
Keywords=ANSI;ASCII;BBS;NFO;RIPscrip;
Exec=bbcat-gtk %f
Icon=dev.bbcat.GtkViewer
Terminal=false
Categories=Graphics;Viewer;
MimeType=application/x-ansi-art;text/x-nfo;application/x-darkdraw;application/x-artworx;application/x-ripscrip;application/x-xbin;
StartupNotify=true
